# Build output.
# Anchored to the repo root: an unanchored `target` would also ignore any
# directory named `target` nested in the source tree.
/target/
/debug/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
**/mutants.out*/

# Profiling output
perf.data
perf.data.old
flamegraph.svg
*.profraw

# Claude Code local permission overrides (machine-specific paths; the shared
# skills and commands under .claude/ are tracked)
.claude/settings.local.json

# Editors
.idea/
.vscode/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db

# Note: Cargo.lock is tracked. Cargo ignores it for consumers of a library, but
# committing it keeps CI builds reproducible.
